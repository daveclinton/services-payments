# macOS
.DS_Store

# IDEs / Editors (optional but recommended)
.idea/
.vscode/
*.swp
*.swo

# Virtual environment (created by the guide: python -m venv .venv)
.venv/
venv/
env/
ENV/

# Environment variables & secrets (very important)
.env
.env.local
.env.* 

# Python cache / compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Django local database (created by `python manage.py migrate`)
db.sqlite3
*.sqlite3
db.sqlite3-journal

# Collected static files (when you later run collectstatic)
staticfiles/

# User-uploaded media files (when you add file uploads)
media/

# Logs
*.log
logs/

# Byte-compiled / packaging (standard Python)
build/
dist/
*.egg-info/
.eggs/
wheels/
*.egg